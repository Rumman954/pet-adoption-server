# Copy this file to .env and replace the placeholder values below.

PORT=5000

# MongoDB Atlas connection string (see SETUP steps in README or ask your instructor)
# Example: mongodb+srv://myuser:MyPass123@cluster0.abc12.mongodb.net/pawhome?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/pawhome?retryWrites=true&w=majority

# Any long random string (at least 32 characters)
JWT_SECRET=change_this_to_a_long_random_secret_string_12345

NODE_ENV=development
CLIENT_URL=http://localhost:5173
